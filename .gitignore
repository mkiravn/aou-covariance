# Genomic data files — never commit these
*.bed
*.bim
*.fam
*.vcf
*.vcf.gz
*.pgen
*.pvar
*.psam
*.bgen
*.mt/
*.ht/
*.bm/

# PLINK output
*.log
*.prune.in
*.prune.out
*.eigenvec
*.eigenval
*.acount
*.grm.bin
*.grm.N.bin
*.grm.id

# Large results / tabular data files -- these are the shape real
# participant-level extracts come in, so default to blocking them
*.tsv
*.txt
*.csv
*.parquet
*.feather
*.rds
*.rdata
*.RData
# keep the small reference files (public panels only) -- note: inline comments
# on a gitignore pattern line are NOT comments, they're part of the pattern
!data/reference/*.panel
# public OMOP concept_ids, not participant data
!02_phenotype/docs/phenotype_list.tsv
!02_phenotype/docs/candidate_phenotypes.tsv

# ID / keep-remove lists -- only ever force-add these for PUBLIC reference
# panel IDs (e.g. 1000 Genomes), never for anything derived from an AoU cohort
*.keep
*.remove

# Python
__pycache__/
*.pyc
.ipynb_checkpoints/
*.egg-info/

# Mac
.DS_Store

# Temporary
*.tmp
*.gstmp
